# -----------------------------------------------------------------------------
# 공통 런타임 설정
# -----------------------------------------------------------------------------
# 모든 Next.js 실행 환경에서 원격 telemetry 전송을 끕니다.
NEXT_TELEMETRY_DISABLED=1

# 개발 컨테이너가 바인드 마운트 파일을 같은 사용자로 다루도록 호스트의
# `id -u`, `id -g` 결과를 설정합니다.
DEV_UID=1000
DEV_GID=1000


# -----------------------------------------------------------------------------
# 서버 전용 외부 연동
# -----------------------------------------------------------------------------
# 향후 LLM 상태 해석에 사용할 OpenAI API 키입니다. 클라이언트에 노출되지 않도록
# NEXT_PUBLIC_ 접두사를 붙이지 마세요.
OPENAI_API_KEY=sk-example-tuti-openai-key

# OpenAI 상태 해석에 사용할 모델입니다. 비워두면 서버 코드의 기본값을 사용합니다.
OPENAI_STATE_MODEL=gpt-4o-mini

# 향후 이벤트 분석에 사용할 PostHog 서버 API 키입니다.
POSTHOG_API_KEY=phc_example_tuti_posthog_key
