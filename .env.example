# 정적 Next/Capacitor 클라이언트가 호출할 외부 API 주소입니다.
# 비워두면 같은 Next 서버의 /api를 사용합니다.
# 배포 예시: https://tuti.today/api
NEXT_PUBLIC_API_BASE_URL=

# 향후 외부 API 서버에서 사용할 DB 연결 주소입니다.
# 클라이언트에 노출되면 안 됩니다.
# Docker 바깥에서 Prisma CLI를 실행할 때는 개발 DB 포트 55432를 사용합니다.
DATABASE_URL=postgresql://tuti_user:tuti_password@localhost:55432/tuti?schema=public

# 향후 LLM 상태 해석에 사용할 OpenAI API 키입니다.
# NEXT_PUBLIC_ 접두사를 붙이지 마세요.
OPENAI_API_KEY=sk-example-tuti-openai-key

# 향후 이벤트 분석에 사용할 PostHog 키입니다.
POSTHOG_API_KEY=phc_example_tuti_posthog_key
