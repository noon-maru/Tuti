{
  "name": "tuti",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "pnpm db:generate && next dev --webpack",
    "build": "pnpm db:generate && next build",
    "build:web": "pnpm db:generate && TUTI_TARGET=web next build",
    "build:app": "pnpm db:generate && TUTI_TARGET=app next build",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "pnpm db:generate && prisma db seed",
    "db:studio": "prisma studio",
    "start": "next start",
    "lint": "pnpm db:generate && eslint",
    "assets:generate": "capacitor-assets generate && node scripts/normalize-capacitor-assets.mjs",
    "cap:sync": "pnpm build:app && cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.100.11",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
