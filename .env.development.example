# -----------------------------------------------------------------------------
# 개발 클라이언트 공개 설정
# -----------------------------------------------------------------------------
# 브라우저 번들에 포함되는 API base URL입니다. 개발 서버에서는 비워두어
# 같은 origin의 /api를 사용합니다.
NEXT_PUBLIC_API_BASE_URL=


# -----------------------------------------------------------------------------
# 개발 서버 DB 연결
# -----------------------------------------------------------------------------
# app 컨테이너에서 Compose의 db 서비스로 접근하는 Prisma 연결 주소입니다.
# 호스트에서 Prisma CLI를 직접 실행할 때는 localhost:55432 주소로 덮어쓰세요.
DATABASE_URL=postgresql://tuti_user:tuti_password@db:5432/tuti?schema=public


# -----------------------------------------------------------------------------
# 개발 DB 컨테이너 초기화
# -----------------------------------------------------------------------------
# PostGIS PostgreSQL 컨테이너가 최초 생성될 때 사용할 계정과 DB 이름입니다.
POSTGRES_USER=tuti_user
POSTGRES_PASSWORD=tuti_password
POSTGRES_DB=tuti
