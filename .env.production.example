# -----------------------------------------------------------------------------
# 배포 런타임 설정
# -----------------------------------------------------------------------------
# Next.js 서버를 production 모드로 실행합니다.
NODE_ENV=production


# -----------------------------------------------------------------------------
# 배포 클라이언트 공개 설정
# -----------------------------------------------------------------------------
# 브라우저 번들에 포함되는 API base URL입니다. Docker build arg로도 전달되므로
# 배포 compose 실행 시 --env-file .env.production을 함께 지정해야 합니다.
NEXT_PUBLIC_API_BASE_URL=https://tuti.today/api


# -----------------------------------------------------------------------------
# 배포 서버 DB 연결
# -----------------------------------------------------------------------------
# app 컨테이너에서 Compose의 db 서비스로 접근하는 Prisma 연결 주소입니다.
DATABASE_URL=postgresql://tuti_user:tuti_password@db:5432/tuti?schema=public


# -----------------------------------------------------------------------------
# 배포 DB 컨테이너 초기화
# -----------------------------------------------------------------------------
# PostGIS PostgreSQL 컨테이너가 최초 생성될 때 사용할 계정과 DB 이름입니다.
# 실제 배포 환경에서는 POSTGRES_PASSWORD를 반드시 교체하세요.
POSTGRES_USER=tuti_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tuti
