generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MovementLevel {
  near
  short
  half
}

model Place {
  id            String                         @id
  name          String
  phrase        String
  note          String
  image         String
  travelTime    String                         @map("travel_time")
  crowd         String
  today         String
  fatigue       Int
  movementLevel MovementLevel                  @map("movement_level")
  moodTags      String[]                       @map("mood_tags")
  latitude      Decimal                        @db.Decimal(9, 6)
  longitude     Decimal                        @db.Decimal(9, 6)
  location      Unsupported("geometry(Point, 4326)")?
  createdAt     DateTime                       @default(now()) @map("created_at")
  updatedAt     DateTime                       @updatedAt @map("updated_at")

  @@index([fatigue])
  @@index([movementLevel])
  @@map("places")
}

model JournalEntry {
  id         String   @id
  title      String
  content    String
  image      String?
  crowd      String
  placeName  String   @map("place_name")
  difficulty String
  visitedAt  DateTime @map("visited_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([visitedAt])
  @@map("journal_entries")
}
